    nAmostras_report_PiezoA3 = 0;
    t_ini_report_PiezoA3 = millis();
  }*/      

  // Reconexão periódica (não bloqueia a coleta)
  if (millis() - ultimaVerificacao >= INTERVALO_VERIFICACAO) {
    ultimaVerificacao = millis();
    verificarConexao();
  }

  clienteMQTT.loop();
}
